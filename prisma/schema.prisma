// ARIA — Autonomous Reasoning & Intelligent Assistant
// Prisma schema for partner-style AI with memory & emotional continuity

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String    @id @default(cuid())
  title     String    @default("New thread")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // 'user' | 'assistant' | 'system'
  content        String
  mood           String?      // assistant mood tag, e.g. 'curious', 'warm'
  toolUsed       String?      // tool name if any was invoked
  toolPayload    String?      // JSON-stringified tool result summary
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// Long-term autobiographical + user-fact memory
// status: "pending" (default, not yet reviewed) → "approved" | "rejected"
// Only "approved" memories are included in LLM recall.
model Memory {
  id         String   @id @default(cuid())
  kind       String   // 'user_fact' | 'preference' | 'event' | 'relationship' | 'project' | 'reflection'
  content    String
  importance Int      @default(5) // 1-10
  status     String   @default("pending") // 'pending' | 'approved' | 'rejected'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([kind])
  @@index([status])
  @@map("memories")
}

// Mood timeline — ARIA's emotional state over time
model MoodLog {
  id        String   @id @default(cuid())
  mood      String
  trigger   String?  // what user message / event caused it
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("mood_logs")
}

// Encrypted provider API keys (ElevenLabs, etc.)
// Stored server-side only — never sent to the browser after initial entry.
// The encryptedKey column holds AES-GCM ciphertext (base64).
model ProviderKey {
  id           String   @id @default(cuid())
  provider     String   @unique // 'elevenlabs' | etc.
  encryptedKey String   // AES-GCM ciphertext, base64
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("provider_keys")
}

// Reminders — ARIA can set and check these via tool calls
model Reminder {
  id        String    @id @default(cuid())
  title     String
  triggerAt DateTime  // when to remind
  completed Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([triggerAt])
  @@index([completed])
  @@map("reminders")
}

// Notes — ARIA can save important things to a journal
model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String   @default("") // comma-separated
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notes")
}

// Proactive messages — generated by ARIA on a schedule
model ProactiveMessage {
  id        String   @id @default(cuid())
  type      String   // 'morning_briefing' | 'silence_check' | 'follow_up'
  content   String
  mood      String   @default("warm")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@map("proactive_messages")
}

// User settings — single-row table for app-wide preferences
model UserSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("user_settings")
}
